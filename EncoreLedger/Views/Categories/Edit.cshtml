@using EncoreLedger.Models
@model Category

<link rel="stylesheet" href="~/css/dashboard.css" />
<link rel="stylesheet" href="~/css/forms.css" />

<h1 class="page-title">Edit Category #@Model.IDCategory</h1>

<div class="form-card">

    <form method="post">

        <input type="hidden" asp-for="IDCategory" />

        <div class="form-grid">

            <div>
                <label>Name</label>
                <input asp-for="Name" />
            </div>

            <div>
                <label>Description</label>
                <input asp-for="Description" />
            </div>

        </div>

        <div style="display:flex; justify-content:flex-end; gap:15px; margin-top:20px;">

            <button type="submit" formaction="@Url.Action("Edit")" class="btn-primary">
                Save
            </button>

            <button type="submit" formaction="@Url.Action("Delete")" class="btn-primary"
                    onclick="return confirm('Are you sure you want to delete this category?');">
                Delete
            </button>

        </div>

    </form>

</div>