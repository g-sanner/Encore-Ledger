@using EncoreLedger.Models
@model Transaction

@{
    ViewData["Title"] = "Create Transaction";
}

<link rel="stylesheet" href="~/css/dashboard.css" />
<link rel="stylesheet" href="~/css/forms.css" />

<h1 class="page-title">Create Transaction</h1>

<form asp-action="Create" method="post">

    <div class="form-card">

        <div class="form-grid">
            @await Html.PartialAsync("_CreateEdit", Model)
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">+ Add</button>
        </div>

    </div>
</form>


<hr style="margin:40px 0;" />


<h2>Import CSV File</h2>

<form asp-action="Import" method="post" enctype="multipart/form-data">

    <div class="form-card">

        <div class="form-grid">

            <div>
                <label>Account</label>
                <select name="accountId" asp-items="ViewBag.Accounts"></select>
            </div>

            <div>
                <label>CSV File</label>
                <input type="file" name="file" accept=".csv" />
            </div>

        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Import</button>
        </div>

    </div>
</form>