@using EncoreLedger.Models
@model Transaction

@{
    ViewData["Title"] = "Edit Transaction #" + Model.IDTransaction;
}

<h1>Edit Transaction #@Model.IDTransaction</h1>

<link rel="stylesheet" href="~/css/dashboard.css" />
<link rel="stylesheet" href="~/css/forms.css" />

<div class="form-card">

    <form method="post">

        <input type="hidden" asp-for="IDTransaction" />

        <div class="form-grid">
            @await Html.PartialAsync("_CreateEdit", Model)

            <div>
                <label>Date Created</label>
                <input asp-for="DateCreated" type="date" readonly />
            </div>

            <div>
                <label>Date Edited</label>
                <input asp-for="DateEdited" type="date" readonly />
            </div>

            <div>
                <label>Import Type</label>
                <input asp-for="InsertType" readonly />
            </div>

            <div>
                <label>Bulk Import</label>
                <input asp-for="BulkImportID" readonly />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Save</button>
            <button type="submit" formaction="@Url.Action("Delete", new { id = Model.IDTransaction })"
                    class="btn-primary" onclick="return confirm('Are you sure you want to delete this transaction?');">
                Delete
            </button>
        </div>

    </form>

</div>