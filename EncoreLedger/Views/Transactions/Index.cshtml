@model EncoreLedger.Models.ViewModels.TransactionIndexViewModel

@{
    ViewData["Title"] = "Transaction Dashboard";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<h1 class="page-title">Transaction Dashboard</h1>

@if (TempData["ImportMessage"] != null)
{
    <div>@TempData["ImportMessage"]</div>
}

<div class="dashboard-container">

    <div class="sidebar">

        <div class="card">
            <h3>Overview</h3>
            <p><strong>Total Transaction Count:</strong> 1</p>
            <p><strong>Last Date Updated:</strong> 02/15/2026</p>
        </div>

        <div class="card">
            <h3>Filter Table</h3>

            <p>
                <input type="checkbox" id="displayAccountName" @(Model.DisplayAccountName ? "checked" : "") />
                Display Account Name
            </p>

            <p><strong>Sort on...</strong></p>

            <select id="sortColumn" class="full-width">
                <option value="Date">Date</option>
                <option value="Category">Category</option>
                <option value="Amount">Amount</option>
            </select>

            <p class="mt-small">
                <input type="checkbox" id="ascending" @(Model.Ascending ? "checked" : "") />
                Ascending
            </p>
        </div>
    </div>

    <div class="main-content">

        <form method="post">

            <div class="table-actions">
                <a asp-action="Create" class="btn-primary">+ Add New</a>

                <div class="action-group">
                    <button type="button" class="btn-primary" onclick="editSelected()">
                        Edit
                    </button>

                    <button type="submit" formaction="@Url.Action("SelectDelete")" class="btn-primary"
                            onclick="return confirm('Are you sure you want to delete this transaction?');">
                        Delete
                    </button>
                </div>
            </div>

            <div id="transactionTable">
                @await Html.PartialAsync("_TransactionTable", Model)
            </div>

        </form>

    </div>
</div>

<script>
    function loadTransactions() {

        const displayAccountName = document.getElementById("displayAccountName").checked;
        const sortColumn = document.getElementById("sortColumn").value;
        const ascending = document.getElementById("ascending").checked;

        fetch(`/Transactions/Filter?displayAccountName=${displayAccountName}&sortColumn=${sortColumn}&ascending=${ascending}`)
            .then(response => response.text())
            .then(html => {
                document.getElementById("transactionTable").innerHTML = html;
            });
    }

    document.getElementById("displayAccountName").addEventListener("change", loadTransactions);
    document.getElementById("sortColumn").addEventListener("change", loadTransactions);
    document.getElementById("ascending").addEventListener("change", loadTransactions);

    function editSelected() {
        const checked = document.querySelectorAll('input[name="selectedIds"]:checked');

        if (checked.length !== 1) {
            alert("Please select exactly one transaction to edit.");
            return;
        }

        const id = checked[0].value;
        window.location.href = '/Transactions/Edit/' + id;
    }
</script>