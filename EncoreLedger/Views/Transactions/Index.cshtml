@{
    ViewData["Title"] = "Transaction Dashboard";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<h1 class="page-title">Transaction Dashboard</h1>

<div class="dashboard-container">

    <div class="sidebar">

        <div class="card">
            <h3>Overview</h3>
            <p><strong>Total Transaction Count:</strong> 1</p>
            <p><strong>Last Date Updated:</strong> 02/15/2026</p>
        </div>

        <div class="card">
            <h3>Filter Table</h3>

            <p>
                <input type="checkbox" />
                Display Account Name
            </p>

            <p><strong>Filter on...</strong></p>

            <select class="full-width">
                <option>Date</option>
                <option>Category</option>
                <option>Amount</option>
            </select>

            <p class="mt-small">
                <input type="checkbox" checked />
                Ascending
            </p>
        </div>

    </div>

    <div class="main-content">

        <div class="table-actions">
            <button class="btn-primary">+ Add New</button>

            <div class="action-group">
                <button class="btn-primary">Edit</button>
                <button class="btn-primary">Delete</button>
            </div>
        </div>

        <table class="ledger-table">
            <thead>
                <tr>
                    <th></th>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Amount</th>
                    <th>Category</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><input type="checkbox" /></td>
                    <td>01/01/2026</td>
                    <td>Mobil</td>
                    <td>$31.47</td>
                    <td>Gas</td>
                    <td>NYC trip</td>
                </tr>
            </tbody>
        </table>

    </div>
</div>
