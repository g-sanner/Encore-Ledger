@model EncoreLedger.Models.ViewModels.TransactionIndexViewModel

@{
    ViewData["Title"] = "Transaction Dashboard";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<h1 class="page-title">Transaction Dashboard</h1>

@if (TempData["ImportMessage"] != null)
{
    <div>@TempData["ImportMessage"]</div>
}

<div class="dashboard-container">

    <div class="sidebar">

        <div class="card">
            <h3>Overview</h3>
            <p>
                <strong>Total Transaction Count:</strong>
                @Model.TotalTransactionCount
            </p>
            <p>
                <strong>Last Date Updated:</strong>
                @(Model.LastDateUpdated?.ToString("MM/dd/yyyy") ?? "N/A")
            </p>
        </div>

        <div class="card">
            <h3>Filter Table</h3>

            <p>
                <input type="checkbox" id="displayAccountName" @(Model.DisplayAccountName ? "checked" : "") />
                Display Account Name
            </p>

            <p><strong>Sort on...</strong></p>

            <select id="sortColumn" class="full-width">
                <option value="Date">Date</option>
                <option value="Category">Category</option>
                <option value="Amount">Amount</option>
            </select>

            <p class="mt-small">
                <input type="checkbox" id="ascending" @(Model.Ascending ? "checked" : "") />
                Ascending
            </p>
        </div>
    </div>

    <div class="main-content">

        <form method="post">

            <div class="table-actions">
                <a asp-action="Create" class="btn-primary">+ Add New</a>

                <div class="action-group">
                    <button type="button" class="btn-primary" onclick="openBulkEdit()">
                        Bulk Edit
                    </button>

                    <button type="button" class="btn-primary" onclick="editSelected()">
                        Edit
                    </button>

                    <button type="submit" formaction="@Url.Action("SelectDelete")" class="btn-primary"
                            onclick="return confirm('Are you sure you want to delete this transaction?');">
                        Delete
                    </button>
                </div>
            </div>

            <div id="transactionTable">
                @await Html.PartialAsync("_TransactionTable", Model)
            </div>

            <div id="bulkEditModal" class="modal-overlay" style="display:none;">
                <div class="modal-window">

                    <div
                        style="background: #1F3D2B; color: white; padding: 15px 20px; border-bottom: 1px solid #C8BDA5; margin: 0;">
                        <h3 style="margin: 0; font-size: 1.1em;">Bulk Edit Transactions</h3>
                    </div>

                    <div>
                        @Html.AntiForgeryToken()

                        <!-- Hidden inputs populated by openBulkEdit() with selected transaction IDs -->
                        <div id="bulkEditSelectedIds"></div>

                        <div>
                            <label for="categorySelect">Category</label>
                            <select id="categorySelect" name="categoryId">
                                <option value="">None</option>
                                @foreach (var c in ViewBag.Categories as SelectList)
                                {
                                    <option value="@c.Value">@c.Text</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label for="accountSelect">Account</label>
                            <select id="accountSelect" name="accountId">
                                <option value="">None</option>
                                @foreach (var a in ViewBag.Accounts as SelectList)
                                {
                                    <option value="@a.Value">@a.Text</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label for="descriptionInput">Description</label>
                            <input type="text" id="descriptionInput" name="description"
                                   placeholder="(Leave blank to keep current)" />
                        </div>

                        <div>
                            <label for="notesInput">Notes</label>
                            <textarea id="notesInput" name="notes"
                                      placeholder="(Leave blank to keep current)"></textarea>
                        </div>

                        <div class="modal-actions">
                            <button type="submit" formaction="@Url.Action("BulkEdit", "Transactions")"
                                    class="btn-primary">
                                Apply Changes
                            </button>

                            <button type="button" class="btn-secondary" onclick="closeBulkEdit()">
                                Cancel
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </form>
    </div>
</div>

<script>
    const filterIds = ["displayAccountName", "sortColumn", "ascending"];

    function getFilters() {
        return {
            displayAccountName: document.getElementById("displayAccountName").checked,
            sortColumn: document.getElementById("sortColumn").value,
            ascending: document.getElementById("ascending").checked
        };
    }

    function saveFilters(filters) {
        localStorage.setItem('displayAccountName', filters.displayAccountName);
        localStorage.setItem('sortColumn', filters.sortColumn);
        localStorage.setItem('ascending', filters.ascending);
    }

    function restoreFilters() {
        const savedDisplayAccount = localStorage.getItem('displayAccountName');
        const savedSortColumn = localStorage.getItem('sortColumn');
        const savedAscending = localStorage.getItem('ascending');

        if (savedDisplayAccount !== null) {
            document.getElementById('displayAccountName').checked = savedDisplayAccount === 'true';
        }
        if (savedSortColumn) {
            document.getElementById('sortColumn').value = savedSortColumn;
        }
        if (savedAscending !== null) {
            document.getElementById('ascending').checked = savedAscending === 'true';
        }
    }

    function applyFilters() {
        const filters = getFilters();
        saveFilters(filters);

        window.location.href = `@Url.Action("Index")` +
            `?displayAccountName=${filters.displayAccountName}` +
            `&sortColumn=${filters.sortColumn}` +
            `&ascending=${filters.ascending}`;
    }

    function loadTransactions() {
        const filters = getFilters();
        saveFilters(filters);

        fetch(`/Transactions/Filter?displayAccountName=${filters.displayAccountName}&sortColumn=${filters.sortColumn}&ascending=${filters.ascending}`)
            .then(response => response.text())
            .then(html => {
                document.getElementById("transactionTable").innerHTML = html;
            });
    }

    function onFilterChange() {
        loadTransactions();
    }

    // Init
    window.addEventListener('DOMContentLoaded', function () {
        restoreFilters();
        loadTransactions();

        filterIds.forEach(id => {
            document.getElementById(id).addEventListener("change", onFilterChange);
        });
    });

    function editSelected() {
        const checked = document.querySelectorAll('input[name="selectedIds"]:checked');

        if (checked.length !== 1) {
            alert("Please select exactly one transaction to edit.");
            return;
        }

        const id = checked[0].value;
        window.location.href = '/Transactions/Edit/' + id;
    }

    function openBulkEdit() {
        const checked = document.querySelectorAll('input[name="selectedIds"]:checked');

        if (checked.length === 0) {
            alert("Please select at least one transaction.");
            return;
        }

        const container = document.getElementById("bulkEditSelectedIds");
        container.innerHTML = "";

        checked.forEach(c => {
            container.innerHTML += `<input type="hidden" name="selectedIds" value="${c.value}" />`;
        });

        document.getElementById("bulkEditModal").style.display = "flex";
    }

    function closeBulkEdit() {
        document.getElementById("bulkEditModal").style.display = "none";
    }
</script>