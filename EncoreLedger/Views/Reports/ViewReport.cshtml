@{
    ViewData["Title"] = "View Report";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<h1 class="page-title">Report: @ViewBag.ReportFileName</h1>

<div style="margin-bottom: 20px;">
    <a href="@Url.Action("Index")" class="btn-primary" style="text-decoration: none; padding: 8px 16px; display: inline-block;">
        ← Back to Reports
    </a>
</div>

<div style="background-color: #f5f5f5; padding: 20px; border-radius: 5px; font-family: monospace; white-space: pre-wrap; word-wrap: break-word; border: 1px solid #ddd; overflow-x: auto;">
    @Model
</div>

<div style="margin-top: 20px;">
    <a href="@Url.Action("DownloadReport", new { id = ViewBag.ReportId })" class="btn-primary" style="text-decoration: none; padding: 8px 16px; display: inline-block;">
        Download PDF
    </a>
</div>
